# Moltis web UI password (set on first launch)
MOLTIS_PASSWORD=

# --- LLM Provider API Keys ---

# OpenRouter (recommended: access to many models via one key)
OPENROUTER_API_KEY=

# OpenAI
OPENAI_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# --- Tool API Keys ---

# Brave Search (enables web search tool)
BRAVE_API_KEY=

# --- MCP Server API Keys ---

# GitHub (enables GitHub MCP server - create token at https://github.com/settings/tokens)
GITHUB_TOKEN=
