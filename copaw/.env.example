# CoPaw Environment Configuration
# Copy this file to .env and update with your actual values

# =============================================================================
# MODEL PROVIDER CONFIGURATION
# =============================================================================

# OpenAI-compatible local model endpoint
# Format: http://<host>:<port>/v1
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=http://your-local-model-endpoint/v1

# Alternative: DashScope (Alibaba Cloud)
# DASHSCOPE_API_KEY=your-dashscope-key-here

# Alternative: Other providers
# ANTHROPIC_API_KEY=your-key-here
# OPENROUTER_API_KEY=your-key-here
# DEEPSEEK_API_KEY=your-key-here

# =============================================================================
# COPAW SETTINGS
# =============================================================================

# Web console port (default: 8088)
COPAW_PORT=8088

# Enabled channels (comma-separated)
# Options: console, dingtalk, feishu, qq, discord, imessage
COPAW_ENABLED_CHANNELS=console

# =============================================================================
# OPTIONAL FEATURES
# =============================================================================

# Tavily API key for web search
# TAVILY_API_KEY=your-tavily-key-here

# Other tool API keys
# SERPER_API_KEY=your-key-here
# BING_API_KEY=your-key-here
