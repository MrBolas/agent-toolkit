# CoPaw Environment Configuration
# Local model: http://192.168.1.50:9293/v1

# =============================================================================
# MODEL PROVIDER CONFIGURATION
# =============================================================================

# OpenAI-compatible local model endpoint
OPENAI_API_KEY=random-key
OPENAI_BASE_URL=http://192.168.1.50:9293/v1

# =============================================================================
# COPAW SETTINGS
# =============================================================================

# Web console port (default: 8088)
COPAW_PORT=8088

# Enabled channels (console only for local development)
COPAW_ENABLED_CHANNELS=console

# =============================================================================
# OPTIONAL FEATURES
# =============================================================================

# Add other API keys here as needed
# TAVILY_API_KEY=your-tavily-key-here
