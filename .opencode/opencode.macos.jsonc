{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["@tarquinen/opencode-dcp@0.4.12"],
  "experimental": {
    "primary_tools": ["prune"]
  },
  "tui": {
    "scroll_speed": 3
  },

  "provider": {
    "local-llama.cpp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Local Llama.cpp",
      "options": {
         "baseURL": "http://192.168.1.50:9293/v1"
      },
       "models": {
          "gpt-oss-120b": {
            "name": "GPT OSS 120B",
            "options": {
              "limit": {
                "context": 150072
              }
            },
            "providerOptions": {
              "local-llama.cpp": {
                "temperature": 1.0,
                "top_p": 1.0,
                "top_k": 0,
                "min_p": 0.0
              }
            }
          },
          "nemotron-3-super-120b-a12b-mxfp4": {
            "name": "Nemotron 3 Super 120B A12B MXFP4",
            "options": {
              "limit": {
                "context": 150072
              }
            },
            "providerOptions": {
              "local-llama.cpp": {
                "temperature": 0.7,
                "top_p": 0.9,
                "top_k": 20
              }
            }
          },
          "qwen3-coder-next-q6": {
            "name": "Qwen3 Coder Next Q6",
            "options": {
              "limit": {
                "context": 150072
              }
            },
            "providerOptions": {
              "local-llama.cpp": {
                "temperature": 1.0,
                "top_p": 0.95,
                "top_k": 40
              }
            }
          },
          "qwen3.5-122b-a10b-mxfp4_instruct": {
            "name": "Qwen3.5 122B A10B MXFP4 Instruct",
            "options": {
              "limit": {
                "context": 150072
              }
            },
            "providerOptions": {
              "local-llama.cpp": {
                "temperature": 0.7,
                "top_p": 0.8,
                "top_k": 20
              }
            }
          },
          "qwen3.5-122b-a10b-mxfp4_thinking": {
            "name": "Qwen3.5 122B A10B MXFP4 Thinking",
            "options": {
              "limit": {
                "context": 150072
              }
            },
            "providerOptions": {
              "local-llama.cpp": {
                "temperature": 0.6,
                "top_p": 0.95,
                "top_k": 20
              }
            }
          },
          "qwen3.5-35b-a3b-ud-mxfp4_instruct": {
            "name": "Qwen3.5 35B A3B UD MXFP4 Instruct",
            "options": {
              "limit": {
                "context": 150072
              }
            },
            "providerOptions": {
              "local-llama.cpp": {
                "temperature": 0.7,
                "top_p": 0.8,
                "top_k": 20
              }
            }
          },
          "qwen3.5-35b-a3b-ud-mxfp4_thinking": {
            "name": "Qwen3.5 35B A3B UD MXFP4 Thinking",
            "options": {
              "limit": {
                "context": 150072
              }
            },
            "providerOptions": {
              "local-llama.cpp": {
                "temperature": 0.6,
                "top_p": 0.95,
                "top_k": 20
              }
            }
          },
          "qwen3.5-4b-ud-q8": {
            "name": "Qwen3.5 4B UD Q8",
            "options": {
              "limit": {
                "context": 150072
              }
            },
            "providerOptions": {
              "local-llama.cpp": {
                "temperature": 0.7,
                "top_p": 0.8,
                "top_k": 20
              }
            }
          }
       }
      }
    },

   "share": "disabled",
    "mcp": {
     "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}"
      },
      "enabled": true
     },
    "serena": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--enable-web-dashboard",
        "false"
      ],
      "enabled": true
    },
    "sequential-thinking": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "--rm",
        "-i",
        "mcp/sequentialthinking"
      ],
      "enabled": true
    },
    "atlassian": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-remote",
        "https://mcp.atlassian.com/v1/sse"
      ],
      "enabled": false
    },
    "github": {
       "type": "local",
       "command": [
         "docker",
         "run",
         "--rm",
         "-i",
         "-e",
         "GITHUB_PERSONAL_ACCESS_TOKEN",
         "ghcr.io/github/github-mcp-server:latest"
       ],
       "enabled": true
    },
    "mastra": {
       "type": "local",
       "command": [
         "npx",
         "-y",
         "@mastra/mcp-docs-server"
       ],
       "enabled": false
    }
   },
   "permission": {
      "bash": {
        "rm -rf *": "deny",
        "rm -rf /": "deny",
        "git push --force": "ask",
        "git push -f": "ask",
        "npm publish": "ask",
        "docker system prune -a": "ask"
      },
    "doom_loop": "ask",
    "external_directory": "ask"
  }
 }
